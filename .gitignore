# ===========================
# General
# ===========================

# Node modules for both frontend and backend
node_modules/
frontend/node_modules/
backend/node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by testing tools like Istanbul
coverage/

# Dependency directories
bower_components/

# TypeScript cache (if applicable)
*.tsbuildinfo

# Optional npm cache directory
.npm/

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables files
.env
frontend/.env
backend/.env

# ===========================
# OS Specific
# ===========================

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ===========================
# Editor and IDE Specific
# ===========================

# Visual Studio Code
.vscode/

# IntelliJ IDEA
.idea/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Eclipse
.project
.classpath
.c9/

# Vim
*.swp
*~

# Emacs
*~

# ===========================
# Frontend Specific
# ===========================

# Frontend build output
frontend/build/
frontend/dist/
frontend/.cache/
frontend/.parcel-cache/

# Frontend environment-specific files
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# ===========================
# Backend Specific
# ===========================

# Backend build output
backend/dist/
backend/build/

# Backend environment-specific files
backend/.env.local
backend/.env.development.local
backend/.env.test.local
backend/.env.production.local

# ===========================
# Git Large File Storage (LFS)
# ===========================

# Track large files with Git LFS instead of Git
*.psd
*.mp4

# ===========================
# Miscellaneous
# ===========================

# Lock files
*.lock
!package-lock.json  # If you want to keep package-lock.json

# Temporary files
tmp/
temp/

# Debugging files
.vs/
*.suo
*.ntvs*
*.njsproj
*.sln

# Frontend Assets
frontend/src/pages/projects/*.png

